  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.mmbot.reminders</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/maiesel/Obsidian/mm_manifatture_web/bot/.venv/bin/python</string>
    <string>/Users/maiesel/Obsidian/mm_manifatture_web/bot/src/reminders/send.py</string>

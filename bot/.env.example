TELEGRAM_TOKEN=
# Comma-separated list of allowed chat ids. Empty = no whitelist (dev only).
TELEGRAM_ALLOWED_CHAT_IDS=
# Legacy single-value form, still read as fallback by config.py.
TELEGRAM_ALLOWED_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=

# Optional Sprint 1 overrides (defaults shown)
# PHOTOS_DIR=bot/photos
# DB_PATH=bot/bot.sqlite
# CATALOG_PATH=web/catalog.json
# INACTIVITY_MINUTES=30

# Set to 1 ONLY for local dev to bypass whitelist (never in production).
# DEV_OPEN_MODE=1

ANTHROPIC_API_KEY=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Meta Graph API (Sprint 4)
# Set META_ENABLED=1 only after: App Review approved + IG Business account linked to FB Page.
# In development mode (app not reviewed) only users added as testers can see published content.
META_ENABLED=0
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=

GITHUB_TOKEN=
GITHUB_REPO=lmaiese/mm_manifatture_web
VERCEL_DEPLOY_HOOK=

# Sprint 5 — Scheduler
# Comma-separated hours (0-23, UTC) for automatic publication slots.
PUBLICATION_SLOTS=10,13,18,21
# Set to 1 to receive a daily summary on Telegram (admin only).
DAILY_REPORT_ENABLED=0

# Reminders — Gmail SMTP
REMINDER_GMAIL_ADDRESS=
REMINDER_GMAIL_APP_PASSWORD=
